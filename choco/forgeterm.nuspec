<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>forgeterm</id>
    <version>0.15.0</version>
    <title>ForgeTerm</title>
    <authors>Nadav Cohen</authors>
    <owners>ncamaa</owners>
    <projectUrl>https://github.com/ncamaa/forgeterm</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/ncamaa/forgeterm/main/build/icon.png</iconUrl>
    <licenseUrl>https://github.com/ncamaa/forgeterm/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Terminal emulator for multi-project workflows. Electron-based with per-project windows, multiple sessions, and configurable themes.</description>
    <summary>Terminal emulator for multi-project workflows</summary>
    <tags>terminal emulator electron developer-tools cli</tags>
    <packageSourceUrl>https://github.com/ncamaa/forgeterm</packageSourceUrl>
    <bugTrackerUrl>https://github.com/ncamaa/forgeterm/issues</bugTrackerUrl>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
